# GlueSync Pipeline Configuration - Environment Variables
# Copy this file to .env and fill in your actual credentials
# NEVER commit .env to version control!

# Core Hub Authentication
GLUESYNC_ADMIN_USERNAME=admin
GLUESYNC_ADMIN_PASSWORD=your_admin_password_here

# AS400 Source Database Credentials
AS400_USERNAME=your_as400_username
AS400_PASSWORD=your_as400_password

# MSSQL Target Database Credentials
MSSQL_USERNAME=your_mssql_username
MSSQL_PASSWORD=your_mssql_password
