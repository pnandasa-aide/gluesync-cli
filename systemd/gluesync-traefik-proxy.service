[Unit]
Description=GlueSync Traefik Proxy (Port 80/443 to 8080/8443)
After=network.target

[Service]
Type=simple
ExecStart=/bin/bash -c 'socat TCP-LISTEN:80,fork TCP:localhost:8080 & socat TCP-LISTEN:443,fork TCP:localhost:8443 & wait'
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
